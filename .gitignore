# Frontend Node build metadata and scripts for web apps
web/shellcast-web-*/package-lock.json
# OpenLayers build (package.json + copy script) is committed under shellcast-web-nc
!web/shellcast-web-nc/package.json
!web/shellcast-web-nc/scripts/copy-ol-to-static.js
# Ignore other scripts under shellcast-web-* (deploy helpers, etc.)
web/shellcast-web-*/scripts/*
!web/shellcast-web-nc/scripts/copy-ol-to-static.js
# Other Node/npm/yarn files (do not push)
**/yarn.lock
**/.nvmrc
**/.node-version
**/.npmrc
**/npm-debug.log*
**/.yarn/
venv/
webenv/
