# Local Development Environment Variables
# Copy this file to .env and fill in your actual values

# Flask Configuration
DEBUG=true
TESTING=false
EMAIL_SECRET_KEY=your-email-secret-key


# Database Configuration (Local)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your-db-username
DB_PASS=your-db-password
DB_NAME=your-db-name

# Cloud SQL Configuration (Local)
DB_UNIX_SOCKET_PATH_PREFIX=path-to-cloudsql-proxy-path
CLOUD_SQL_INSTANCE_NAME=your-cloud-sql-instance-name

# SQLAlchemy Configuration (adjust if needed)
SQLALCHEMY_TRACK_MODIFICATIONS=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
