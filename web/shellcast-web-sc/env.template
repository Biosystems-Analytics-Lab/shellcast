# Local Development Environment Variables for SC
# Copy this file to .env and fill in your actual values

# Flask Configuration
DEBUG=true
TESTING=false
SECRET_KEY=your-secret-key
EMAIL_SECRET_KEY=your-email-secret-key

# Server (optional; defaults used if not set)
HOST=127.0.0.1
PORT=3361

# Database Configuration
DB_USER=your-db-username
DB_PASS=your-db-password
DB_NAME=shellcast_sc

# Cloud SQL Configuration (local proxy: ./my-cloud-sql-proxy.sh web from repo root)
DB_UNIX_SOCKET_PATH_PREFIX=/tmp/shellcast-csql/
CLOUD_SQL_INSTANCE_NAME=your-project:region:instance-name

# SQLAlchemy Configuration (adjust if needed)
SQLALCHEMY_TRACK_MODIFICATIONS=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# NC centralized logging (required for SMS events to appear in notification_events)
# NC_LOG_URL=https://shellcast-web-nc-dot-<project>.appspot.com
# For local testing: http://localhost:8080 (NC app must be running)
# NC_LOG_SECRET=your-nc-log-secret

# Optional: NC orchestrator secret (for NC triggering SC /send-bandwidth-message)
# NC_ORCHESTRATOR_SECRET=your-orchestrator-secret

# Bandwidth SMS configuration (optional for local tests)
# BW_USERNAME=your-bandwidth-username
# BW_PASSWORD=your-bandwidth-password
# BW_APPLICATION_ID=your-bandwidth-application-id
# BW_ACCOUNT_ID=your-bandwidth-account-id
# BW_NUMBER=+1xxxxxxxxxx
