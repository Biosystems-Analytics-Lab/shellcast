# Local Development Environment Variables for NC
# Copy this file to .env and fill in your actual values

# Flask Configuration
DEBUG=true
TESTING=false
SECRET_KEY=your-secret-key
EMAIL_SECRET_KEY=your-email-secret-key

# Server (optional; defaults used if not set)
HOST=127.0.0.1
PORT=3361

# Database Configuration (Local)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your-db-username
DB_PASS=your-db-password
DB_NAME=shellcast_nc

# Cloud SQL Configuration (Local)
DB_UNIX_SOCKET_PATH_PREFIX=./cloudsql/
CLOUD_SQL_INSTANCE_NAME=ncsu-shellcast:us-east1:ncsu-shellcast-database

# SQLAlchemy Configuration (adjust if needed)
SQLALCHEMY_TRACK_MODIFICATIONS=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# AWS SES (optional; for email notifications)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
