# Local Development Environment Variables
# Copy this file to .env and fill in your actual values

# Flask Configuration
DEBUG=true
TESTING=false
EMAIL_SECRET_KEY=your-email-secret-key

# Preferences: set false to disable text notification UI (testing); cron SMS unchanged
TEXT_NOTIFICATIONS_UI_ENABLED=true
TEXT_NOTIFICATIONS_DISABLED_MESSAGE=Text notifications are temporarily unavailable while we complete testing.

# Database Configuration
DB_USER=your-db-username
DB_PASS=your-db-password
DB_NAME=your-db-name

# Cloud SQL Configuration (local proxy: ./my-cloud-sql-proxy.sh web from repo root)
DB_UNIX_SOCKET_PATH_PREFIX=/tmp/shellcast-csql/
CLOUD_SQL_INSTANCE_NAME=your-project:region:instance-name

# SQLAlchemy Configuration (adjust if needed)
SQLALCHEMY_TRACK_MODIFICATIONS=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# NC centralized logging (required for SMS events to appear in notification_events)
# NC_LOG_URL=https://shellcast-web-nc-dot-<project>.appspot.com
# For local testing: http://localhost:8080 (NC app must be running)
# NC_LOG_SECRET=your-nc-log-secret

# Optional: NC orchestrator secret (for NC triggering FL /send-bandwidth-message)
# NC_ORCHESTRATOR_SECRET=your-orchestrator-secret

# Bandwidth SMS (optional for local callback tests)
# BW_USERNAME=...
# BW_PASSWORD=...
# BW_APPLICATION_ID=...
# BW_ACCOUNT_ID=...
# BW_NUMBER=+1xxxxxxxxxx
